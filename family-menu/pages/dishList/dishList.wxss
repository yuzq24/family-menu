/* 菜品列表页样式 */

.page {
  min-height: 100vh;
  background: var(--color-bg-secondary);
  padding-bottom: calc(var(--tab-bar-height) + var(--safe-area-bottom));
}

/* 搜索栏 */
.search-bar {
  padding: 10px 16px 8px;
  background: var(--color-bg-primary);
}

.search-input-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.search-icon {
  position: absolute;
  left: 12px;
  width: 16px;
  height: 16px;
  opacity: 0.4;
}

.search-input {
  width: 100%;
  height: 36px;
  padding: 0 12px 0 36px;
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-bg-tertiary);
  border-radius: 18px;
  font-size: var(--text-sm);
  color: var(--color-text-primary);
}

.search-placeholder {
  color: var(--color-text-tertiary);
}

/* 分类标签 */
.category-tabs {
  padding: 4px 16px 12px;
  background: var(--color-bg-primary);
  white-space: nowrap;
}

.category-list {
  display: flex;
  gap: 8px;
}

.category-item {
  flex-shrink: 0;
  height: 32px;
  padding: 0 16px;
  line-height: 32px;
  border-radius: 16px;
  font-size: var(--text-sm);
  background: var(--color-bg-primary);
  color: var(--color-text-secondary);
  border: 1px solid var(--color-bg-tertiary);
}

.category-item.active {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-color: var(--color-primary);
}

/* 菜品网格 */
.dish-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  padding: 0 16px 16px;
}

.dish-card {
  background: var(--color-bg-elevated);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.dish-image-wrap {
  aspect-ratio: 1:1;
  overflow: hidden;
}

.dish-image {
  width: 100%;
  height: 100%;
}

.dish-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 48px;
  opacity: 0.6;
}

.dish-info {
  padding: 10px;
}

.dish-name {
  display: block;
  font-size: 15px;
  font-weight: var(--weight-semibold);
  color: var(--color-text-primary);
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-desc {
  display: block;
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  line-height: 1.4;
  margin-top: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8px;
}

.dish-price {
  font-size: 17px;
  font-weight: var(--weight-bold);
  color: var(--color-primary);
  white-space: nowrap;
}

.add-btn {
  height: 32px;
  padding: 0 12px;
  line-height: 32px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-primary);
  background: var(--color-primary-subtle);
  color: var(--color-primary);
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
}

.add-btn:active {
  background: var(--color-primary-light);
}

/* 悬浮新增按钮 */
.fab {
  position: fixed;
  bottom: 100px;
  right: 16px;
  width: 50px;
  height: 50px;
  border-radius: 25px;
  background: var(--color-primary);
  box-shadow: var(--shadow-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 25;
}

.fab:active {
  transform: scale(0.95);
}

.fab-icon {
  font-size: 24px;
  color: white;
  font-weight: bold;
}
