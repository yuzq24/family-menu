/* 购物车页样式 */

.page {
  min-height: 100vh;
  background: var(--color-bg-secondary);
  padding-bottom: calc(var(--tab-bar-height) + var(--safe-area-bottom));
}

/* 购物车列表 */
.cart-list {
  margin: 12px;
  background: var(--color-bg-elevated);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 12px 16px;
}

.cart-item:not(:last-child) {
  border-bottom: 1px solid var(--color-divider);
}

.item-image {
  width: 64px;
  height: 64px;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

.item-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 24px;
  opacity: 0.6;
}

.item-info {
  flex: 1;
  margin-left: 12px;
  min-width: 0;
}

.item-name {
  display: block;
  font-size: 15px;
  font-weight: var(--weight-semibold);
  color: var(--color-text-primary);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-desc {
  display: block;
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  margin-top: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8px;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 8px;
}

.stepper-btn {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stepper-btn.minus {
  border: 1px solid var(--color-border-strong);
  background: transparent;
}

.stepper-btn.plus {
  background: var(--color-primary);
  border: none;
}

.stepper-icon {
  font-size: 14px;
  color: var(--color-text-tertiary);
}

.stepper-btn.plus .stepper-icon {
  color: var(--color-text-inverse);
}

.stepper-value {
  min-width: 20px;
  text-align: center;
  font-size: var(--text-base);
  font-weight: var(--weight-medium);
  color: var(--color-text-primary);
}

.item-price {
  font-size: var(--text-sm);
  font-weight: var(--weight-bold);
  color: var(--color-primary);
}

.swipe-hint {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0 16px 8px;
}

.swipe-text {
  font-size: var(--text-xs);
  color: var(--state-error);
  font-weight: var(--weight-medium);
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 80px;
}

.empty-icon-wrap {
  width: 96px;
  height: 96px;
  border-radius: 50%;
  background: var(--color-bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}

.empty-icon {
  font-size: 40px;
}

.empty-title {
  font-size: var(--text-md);
  color: var(--color-text-secondary);
  font-weight: var(--weight-medium);
  margin-bottom: 4px;
}

.empty-desc {
  font-size: var(--text-sm);
  color: var(--color-text-tertiary);
  margin-bottom: 24px;
}

.go-shopping-btn {
  height: 44px;
  padding: 0 24px;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-radius: var(--radius-lg);
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 订单摘要 */
.order-summary {
  margin: 12px;
  padding: 16px;
  background: var(--color-bg-elevated);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-label {
  font-size: var(--text-base);
  color: var(--color-text-secondary);
}

.summary-label.bold {
  font-weight: var(--weight-semibold);
  color: var(--color-text-primary);
}

.summary-value {
  font-size: var(--text-base);
  color: var(--color-text-primary);
}

.summary-divider {
  height: 1px;
  background: var(--color-divider);
  margin: 12px 0;
}

.summary-price {
  font-size: 20px;
  font-weight: var(--weight-bold);
  color: var(--color-primary);
}

/* 底部提交栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 40;
  background: var(--color-bg-elevated);
  box-shadow: 0 -1px 0 var(--color-divider), var(--shadow-lg);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
}

.total-info {
  display: flex;
  align-items: baseline;
  gap: 4px;
}

.total-label {
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
}

.total-price {
  font-size: 20px;
  font-weight: var(--weight-bold);
  color: var(--color-primary);
}

.submit-btn {
  height: 44px;
  padding: 0 32px;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-radius: var(--radius-lg);
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn:active {
  background: var(--color-primary-hover);
}
