<view class="page">
  <view class="order-items">
    <view class="section-title">订单菜品</view>
    <view wx:for="{{orderItems}}" wx:key="id" class="order-item">
      <view class="item-image-placeholder">
        <text class="item-emoji">{{item.emoji}}</text>
      </view>
      <view class="item-info">
        <view class="item-name">{{item.name}}</view>
        <view class="item-quantity">x{{item.quantity}}</view>
      </view>
      <view class="item-price">¥{{item.subtotalText}}</view>
    </view>
  </view>

  <view class="order-summary">
    <view class="summary-row">
      <text class="summary-label">商品金额</text>
      <text class="summary-value">¥{{totalPrice}}</text>
    </view>
    <view class="summary-row">
      <text class="summary-label">配送费</text>
      <text class="summary-value">¥0.00</text>
    </view>
    <view class="divider"></view>
    <view class="summary-row total-row">
      <text class="total-label">合计</text>
      <text class="total-price">¥{{totalPrice}}</text>
    </view>
  </view>

  <view class="submit-section">
    <view class="submit-btn" bindtap="onSubmit">提交订单</view>
  </view>
</view>
