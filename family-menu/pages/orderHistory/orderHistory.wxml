<!-- 订单历史页 -->
<view class="page">
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-content">
      <view class="nav-left">
        <view class="back-btn" bindtap="onBack">
          <text class="back-icon">‹</text>
        </view>
      </view>
      <view class="nav-title">订单历史</view>
      <view class="nav-right">
        <view class="capsule-btn">
          <text class="capsule-icon">···</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 状态筛选标签 -->
  <view class="filter-tabs">
    <view wx:for="{{statusTabs}}" wx:key="index" class="filter-tab {{currentStatus === index ? 'active' : ''}}" bindtap="onStatusTap" data-index="{{index}}">
      {{item}}
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view wx:for="{{filteredOrders}}" wx:key="id" class="order-card">
      <view class="order-top">
        <text class="order-id">订单号 #{{item.id}}</text>
        <view class="order-status status-{{item.status}}">
          <text>{{item.statusText}}</text>
        </view>
      </view>
      <text class="order-dishes">{{item.dishText}}</text>
      <view class="order-bottom">
        <text class="order-total">合计 ¥{{item.total}}</text>
        <text class="order-time">{{item.time}}</text>
      </view>
      <view wx:if="{{item.status === 'completed' || item.status === 'making'}}" class="reorder-btn" bindtap="onReorder" data-index="{{index}}">再来一单</view>
    </view>

    <!-- 无订单 -->
    <view class="empty-orders" wx:if="{{filteredOrders.length === 0}}">
      <text class="empty-text">暂无订单</text>
    </view>
  </view>
</view>
