/* 订单历史页样式 */

.page {
  min-height: 100vh;
  background: var(--color-bg-secondary);
  padding-bottom: calc(var(--tab-bar-height) + var(--safe-area-bottom));
}

/* 导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 30;
  background: var(--color-bg-primary);
  border-bottom: 1px solid var(--color-divider);
}

.nav-content {
  display: flex;
  align-items: center;
  height: var(--nav-bar-height);
  padding: 0 4px;
}

.nav-left, .nav-right {
  width: 88px;
  display: flex;
  align-items: center;
}

.nav-left {
  justify-content: flex-start;
  padding-left: 4px;
}

.nav-right {
  justify-content: flex-end;
}

.back-btn {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 24px;
  color: var(--color-text-primary);
  font-weight: bold;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: var(--text-md);
  font-weight: var(--weight-semibold);
  color: var(--color-text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.capsule-btn {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-full);
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: var(--color-text-secondary);
}

/* 筛选标签 */
.filter-tabs {
  position: fixed;
  top: calc(var(--status-bar-height) + var(--nav-bar-height));
  left: 0;
  right: 0;
  z-index: 20;
  background: var(--color-bg-primary);
  padding: 12px 16px 8px;
}

.filter-tabs {
  display: inline-flex;
  background: var(--color-bg-tertiary);
  border-radius: var(--radius-sm);
  padding: 2px;
}

.filter-tab {
  padding: 6px 14px;
  border-radius: var(--radius-xs);
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  background: transparent;
}

.filter-tab.active {
  background: var(--color-bg-primary);
  color: var(--color-text-primary);
  font-weight: var(--weight-semibold);
  box-shadow: var(--shadow-sm);
}

/* 订单列表 */
.order-list {
  padding: calc(var(--status-bar-height) + var(--nav-bar-height) + 60px) 16px 16px;
}

.order-card {
  background: var(--color-bg-elevated);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  padding: 16px;
  margin-bottom: 12px;
}

.order-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.order-id {
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
}

.order-status {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: var(--weight-medium);
}

.order-status.status-pending {
  background: var(--state-warning-bg);
  color: var(--state-warning);
}

.order-status.status-making {
  background: var(--state-info-bg);
  color: var(--state-info);
}

.order-status.status-completed {
  background: var(--state-success-bg);
  color: var(--state-success);
}

.order-dishes {
  display: block;
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  line-height: 1.5;
  margin-bottom: 8px;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.order-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-total {
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--color-primary);
}

.order-time {
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
}

.reorder-btn {
  margin-top: 12px;
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  color: var(--color-primary);
  background: transparent;
  border: none;
  padding: 0;
}

/* 无订单 */
.empty-orders {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px 0;
}

.empty-text {
  font-size: var(--text-sm);
  color: var(--color-text-tertiary);
}
