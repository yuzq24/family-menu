/* 菜品详情页样式 */

.page {
  min-height: 100vh;
  background: var(--color-bg-secondary);
}

/* 自定义导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 30;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--color-border);
}

.nav-content {
  display: flex;
  align-items: center;
  height: var(--nav-bar-height);
  padding: 0 4px;
}

.nav-left, .nav-right {
  width: 88px;
  display: flex;
  align-items: center;
}

.nav-left {
  justify-content: flex-start;
  padding-left: 4px;
}

.nav-right {
  justify-content: flex-end;
}

.back-btn {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-sm);
  background: var(--color-bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 20px;
  color: var(--color-text-primary);
  font-weight: bold;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: var(--text-md);
  font-weight: var(--weight-semibold);
  color: var(--color-text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.capsule-btn {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-full);
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: var(--color-text-secondary);
}

/* 主内容 */
.content {
  padding-bottom: 100px;
}

/* Hero图片 */
.hero-image {
  width: 100%;
  height: 240px;
  overflow: hidden;
}

.hero-img {
  width: 100%;
  height: 100%;
}

.hero-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF6B35 0%, #FF9F0A 100%);
}

.placeholder-icon {
  font-size: 64px;
  opacity: 0.6;
}

/* 信息卡片 */
.info-card {
  margin: -20px 16px 12px;
  padding: 20px;
  background: var(--color-bg-elevated);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  position: relative;
  z-index: 10;
}

.dish-name {
  display: block;
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
  color: var(--color-text-primary);
  line-height: 1.3;
}

.dish-desc {
  display: block;
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  line-height: 1.5;
  margin-top: 8px;
}

.dish-meta {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: 16px;
  flex-wrap: wrap;
}

.dish-price {
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
  color: var(--color-primary);
}

.meta-tags {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.meta-tag {
  display: inline-flex;
  align-items: center;
  padding: 4px 12px;
  border-radius: var(--radius-sm);
  background: var(--color-bg-secondary);
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
}

.tag-icon {
  margin-right: 4px;
}

.tag-text {
  white-space: nowrap;
}

/* 区域卡片 */
.section-card {
  margin: 0 16px 12px;
  padding: 20px;
  background: var(--color-bg-elevated);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

.section-title {
  display: block;
  font-size: var(--text-lg);
  font-weight: var(--weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 16px;
}

/* 食材配料 */
.ingredients-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
}

.ingredient-tag {
  padding: 8px 12px;
  border-radius: var(--radius-sm);
  background: var(--color-bg-secondary);
  font-size: var(--text-sm);
  color: var(--color-text-primary);
  text-align: center;
}

/* 营养信息 */
.nutrition-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  text-align: center;
}

.nutrition-item {
  display: flex;
  flex-direction: column;
}

.nutrition-value {
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
  color: var(--color-primary);
  font-variant-numeric: tabular-nums;
}

.nutrition-label {
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  margin-top: 4px;
}

/* 烹饪步骤 */
.steps-list {
  display: flex;
  flex-direction: column;
}

.step-item {
  display: flex;
  position: relative;
  padding-bottom: 20px;
}

.step-item:last-child {
  padding-bottom: 0;
}

.step-number {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.step-number.last {
  background: var(--color-primary);
}

.step-line {
  position: absolute;
  left: 14px;
  top: 28px;
  width: 1px;
  height: calc(100% - 28px);
  background: var(--color-border-strong);
}

.step-text {
  flex: 1;
  margin-left: 12px;
  padding-top: 4px;
  font-size: var(--text-base);
  color: var(--color-text-primary);
  line-height: 1.5;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 40;
  background: var(--color-bg-primary);
  box-shadow: var(--shadow-lg);
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 12px 16px;
}

.stepper {
  display: flex;
  align-items: center;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-lg);
  padding: 4px;
}

.stepper-btn {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
}

.stepper-btn.minus {
  border: 1px solid var(--color-border-strong);
  background: transparent;
}

.stepper-btn.plus {
  background: var(--color-primary);
}

.stepper-icon {
  font-size: 16px;
  color: var(--color-text-primary);
}

.stepper-btn.plus .stepper-icon {
  color: var(--color-text-inverse);
}

.stepper-value {
  min-width: 24px;
  text-align: center;
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: var(--color-text-primary);
}

.add-cart-btn {
  flex: 1;
  height: var(--control-height-lg);
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-radius: var(--radius-md);
  font-size: var(--text-md);
  font-weight: var(--weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-cart-btn:active {
  opacity: 0.85;
}
