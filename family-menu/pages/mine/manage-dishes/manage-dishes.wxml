<view class="page">
  <view class="dish-list">
    <view wx:for="{{dishes}}" wx:key="id" class="dish-item">
      <view class="dish-image-placeholder">
        <text class="dish-emoji">{{item.emoji}}</text>
      </view>
      <view class="dish-info">
        <view class="dish-name">{{item.name}}</view>
        <view class="dish-category">{{getCategoryName(item.category)}}</view>
        <view class="dish-price">¥{{item.price}}</view>
      </view>
      <view class="dish-delete" bindtap="onDeleteDish" data-id="{{item.id}}">
        <text>删除</text>
      </view>
    </view>
  </view>

  <view wx:if="{{dishes.length === 0}}" class="empty-state">
    <text class="empty-text">暂无菜品</text>
  </view>
</view>
