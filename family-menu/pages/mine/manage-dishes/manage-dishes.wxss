.page {
  min-height: 100vh;
  background-color: #F5F5F7;
  padding: 12px 16px;
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.dish-item {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 14px;
}

.dish-image-placeholder {
  width: 60px;
  height: 60px;
  background: linear-gradient(135deg, #FFF8E7 0%, #FFE4C4 100%);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dish-emoji {
  font-size: 28px;
}

.dish-info {
  flex: 1;
  margin-left: 14px;
}

.dish-name {
  font-size: 16px;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 4px;
}

.dish-category {
  font-size: 13px;
  color: #86868B;
  margin-bottom: 4px;
}

.dish-price {
  font-size: 15px;
  font-weight: 600;
  color: #FF9500;
}

.dish-delete {
  padding: 8px 16px;
  color: #FF3B30;
  font-size: 14px;
  font-weight: 500;
}

.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60px 0;
}

.empty-text {
  font-size: 15px;
  color: #86868B;
}
