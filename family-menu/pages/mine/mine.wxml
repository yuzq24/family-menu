<view class="page">
  <view class="user-section">
    <view class="user-avatar">👨‍🍳</view>
    <view class="user-name">家庭厨师</view>
    <view class="user-desc">让吃饭变得简单</view>
  </view>

  <view class="menu-section">
    <view class="section-title">菜单管理</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="onAddDish">
        <view class="menu-icon">➕</view>
        <view class="menu-text">新增菜品</view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-item" bindtap="onManageDishes">
        <view class="menu-icon">📋</view>
        <view class="menu-text">管理菜品</view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
  </view>

  <view class="order-section">
    <view class="section-title">订单记录</view>
    <view class="order-list">
      <view wx:for="{{orders}}" wx:key="id" class="order-card">
        <view class="order-header">
          <view class="order-id">订单号: {{item.id}}</view>
          <view class="order-status {{item.status}}">{{getStatusText(item.status)}}</view>
        </view>
        <view class="order-items-preview">
          <text wx:for="{{item.items}}" wx:key="dishId" wx:for-item="orderItem" class="order-item-text">
            {{getDishName(orderItem.dishId)}} x{{orderItem.quantity}}
          </text>
        </view>
        <view class="order-footer">
          <view class="order-time">{{formatTime(item.createdAt)}}</view>
          <view class="order-total">¥{{item.totalPrice}}</view>
        </view>
      </view>

      <view wx:if="{{orders.length === 0}}" class="empty-orders">
        <text>暂无订单记录</text>
      </view>
    </view>
  </view>
</view>
