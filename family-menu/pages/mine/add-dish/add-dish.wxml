<view class="page">
  <view class="form-section">
    <view class="form-item">
      <view class="form-label">菜品名称</view>
      <input class="form-input" placeholder="请输入菜品名称" bindinput="onNameInput" value="{{name}}" />
    </view>

    <view class="form-item">
      <view class="form-label">菜品分类</view>
      <picker mode="selector" range="{{categories}}" range-key="name" bindchange="onCategoryChange">
        <view class="form-picker">
          <text>{{selectedCategory.name || '请选择分类'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">价格（元）</view>
      <input class="form-input" type="digit" placeholder="请输入价格" bindinput="onPriceInput" value="{{price}}" />
    </view>

    <view class="form-item">
      <view class="form-label">菜品描述</view>
      <textarea class="form-textarea" placeholder="请输入菜品描述" bindinput="onDescInput" value="{{description}}"></textarea>
    </view>
  </view>

  <view class="submit-section">
    <view class="submit-btn" bindtap="onSubmit">保存菜品</view>
  </view>
</view>
