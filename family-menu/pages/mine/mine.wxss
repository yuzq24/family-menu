.page {
  min-height: 100vh;
  background-color: #F5F5F7;
  padding-bottom: 20px;
}

.user-section {
  background-color: #FFFFFF;
  padding: 32px 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 12px;
}

.user-avatar {
  width: 80px;
  height: 80px;
  background: linear-gradient(135deg, #FFF8E7 0%, #FFE4C4 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
  margin-bottom: 12px;
}

.user-name {
  font-size: 20px;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 4px;
}

.user-desc {
  font-size: 14px;
  color: #86868B;
}

.menu-section, .order-section {
  background-color: #FFFFFF;
  margin: 0 16px 12px;
  border-radius: 12px;
  padding: 16px;
}

.section-title {
  font-size: 17px;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 12px;
}

.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid #F5F5F7;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 32px;
  height: 32px;
  background-color: #FFF8E7;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  margin-right: 12px;
}

.menu-text {
  flex: 1;
  font-size: 15px;
  color: #1D1D1F;
}

.menu-arrow {
  font-size: 20px;
  color: #C7C7CC;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.order-card {
  background-color: #F5F5F7;
  border-radius: 10px;
  padding: 14px;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.order-id {
  font-size: 13px;
  color: #86868B;
}

.order-status {
  font-size: 12px;
  padding: 2px 8px;
  border-radius: 4px;
  font-weight: 500;
}

.order-status.pending {
  background-color: #FFF3E0;
  color: #FF9500;
}

.order-status.confirmed {
  background-color: #E8F5E9;
  color: #34C759;
}

.order-status.completed {
  background-color: #F5F5F7;
  color: #86868B;
}

.order-status.cancelled {
  background-color: #FFEBEE;
  color: #FF3B30;
}

.order-items-preview {
  font-size: 14px;
  color: #1D1D1F;
  margin-bottom: 10px;
}

.order-item-text {
  margin-right: 12px;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-time {
  font-size: 12px;
  color: #86868B;
}

.order-total {
  font-size: 16px;
  font-weight: 600;
  color: #FF9500;
}

.empty-orders {
  text-align: center;
  padding: 30px 0;
  font-size: 14px;
  color: #86868B;
}
